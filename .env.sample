# Rails Environment (set dynamically via -e flag or defaults to development)
# RAILS_ENV=development
RACK_ENV=development

# Database Configuration  
# Note: DATABASE_URL will be overridden by database.yml for specific environments
# This serves as a template/default
DATABASE_URL=postgresql://postgres:password@db:5432/xptrackr_?

# Rails Secret Key Base (generate with: rails secret)
SECRET_KEY_BASE=generate_your_own_secret_key_base_with_rails_secret

# Redis Configuration (if using Redis)
REDIS_URL=redis://redis:6379/0

# Rails Server Configuration
RAILS_SERVE_STATIC_FILES=true
RAILS_LOG_TO_STDOUT=true

# Application Configuration
APP_NAME=XPTrackr
APP_VERSION=1.0.0

# CORS Configuration (if needed)
CORS_ORIGINS=http://localhost:3001,http://localhost:8080

# Email Configuration (example for development)
SMTP_ADDRESS=localhost
SMTP_PORT=1025
SMTP_DOMAIN=localhost
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTHENTICATION=
SMTP_ENABLE_STARTTLS_AUTO=false

# External API Keys (replace with actual values)
# API_KEY=your_api_key_here
# THIRD_PARTY_SERVICE_URL=https://api.example.com
